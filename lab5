#include <iostream>

using namespace std;

#define MAX 100

// --- STACK IMPLEMENTATION ---
struct Stack {
    int arr[MAX];
    int top;
};

void initStack(Stack* s) { 
    s->top = -1; 
}

bool isStackEmpty(Stack* s) { 
    return s->top == -1; 
}

void push(Stack* s, int val) {
    if (s->top < MAX - 1) {
        s->arr[++(s->top)] = val;
    }
}

int pop(Stack* s) {
    if (!isStackEmpty(s)) {
        return s->arr[(s->top)--];
    }
    return -1;
}

void printStack(Stack* s) {
    if (isStackEmpty(s)) {
        cout << "Stack is empty." << endl;
        return;
    }
    cout << "[Top] ";
    for (int i = s->top; i >= 0; i--) {
        cout << s->arr[i] << " ";
    }
    cout << "[Bottom]" << endl;
}

// --- QUEUE IMPLEMENTATION ---
struct Queue {
    int arr[MAX];
    int front;
    int rear;
};

void initQueue(Queue* q) { 
    q->front = -1; 
    q->rear = -1; 
}

bool isQueueEmpty(Queue* q) { 
    return (q->front == -1 || q->front > q->rear); 
}

void enqueue(Queue* q, int val) {
    if (q->rear < MAX - 1) {
        if (q->front == -1) q->front = 0;
        q->arr[++(q->rear)] = val;
    }
}

int dequeue(Queue* q) {
    if (!isQueueEmpty(q)) {
        return q->arr[(q->front)++];
    }
    return -1;
}

// ==========================================
// CORE LOGIC: TRANSFER WITH ORDER PRESERVED
// ==========================================
void transferStack(Stack* source, Stack* destination) {
    Queue tempQueue;
    initQueue(&tempQueue);

    // 1. Source -> Destination (Sıralama ters döner)
    while (!isStackEmpty(source)) {
        push(destination, pop(source));
    }

    // 2. Destination -> Queue (Kuyruğa geçer)
    while (!isStackEmpty(destination)) {
        enqueue(&tempQueue, pop(destination));
    }

    // 3. Queue -> Destination (Sıralama orijinal haline döner)
    while (!isQueueEmpty(&tempQueue)) {
        push(destination, dequeue(&tempQueue));
    }
}

int main() {
    Stack stackA, stackB;
    initStack(&stackA);
    initStack(&stackB);

    // Kullanıcıdan giriş alma
    cout << "Lutfen 5 adet tam sayi giriniz (Her sayidan sonra Enter'a basin):" << endl;
    for(int i = 0; i < 5; i++) {
        int val;
        if (!(cin >> val)) break; 
        push(&stackA, val);
    }

    cout << "\n--- TRANSFER ONCESI ---" << endl;
    cout << "Stack A: ";
    printStack(&stackA);
    cout << "Stack B: ";
    printStack(&stackB);

    // Transfer işlemini başlat
    transferStack(&stackA, &stackB);

    cout << "\n--- TRANSFER SONRASI ---" << endl;
    cout << "Stack A: ";
    printStack(&stackA);
    cout << "Stack B: ";
    printStack(&stackB);

    return 0;
}
